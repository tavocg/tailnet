TS_HOSTNAME=bazarr
TS_AUTHKEY=tskey-client-nnn-nnn
TS_EXTRA_ARGS=--advertise-tags=tag:container
TS_ALLOW_FUNNEL=false

PUID=1000
PGID=1001

BASE_DATA_DIR=/mnt/storage/data

BAZARR_CONFIG_DIR=${BASE_DATA_DIR:-.}/bazarr/config
BAZARR_MOVIES_DIR=/mnt/storage/media/movies
BAZARR_TV_DIR=/mnt/storage/media/shows
