TS_HOSTNAME=dokploy
TS_AUTHKEY=tskey-client-nnn-nnn
TS_EXTRA_ARGS=--advertise-tags=tag:container
TS_ALLOW_FUNNEL=false

# Cloudflare Tunnel token from Zero Trust > Networks > Tunnels.
CLOUDFLARED_TOKEN=eyJhIjoi...replace-me
# Configure Cloudflare Tunnel public hostnames like:
#   *.example.com       -> http://dokploy-traefik:80
#   *.otherdomain.com   -> http://dokploy-traefik:80
#
# Dokploy should then route each app by domain, for example:
#   app1.example.com
#   app2.example.com

DOKPLOY_POSTGRES_PASSWORD=change-me-generate-a-long-random-password
BETTER_AUTH_SECRET=change-me-generate-a-long-random-secret
DOKPLOY_CONFIG_DIR=/mnt/storage/data/dokploy/config
