# Cloudflare Tunnel token from Zero Trust > Networks > Tunnels.
# Configure the tunnel public hostname:
#   humangame.asafut.com -> http://wordpress:80
CLOUDFLARED_TOKEN=eyJhIjoi...replace-me
COMPOSE_PROJECT_NAME=humangame
WORDPRESS_SITE_SLUG=humangame.asafut.com
WORDPRESS_DOMAIN=humangame.asafut.com
WORDPRESS_SITE_NAME=ASAFUT Human Game

BASE_DATA_DIR=/mnt/storage/data
WORDPRESS_DATA_DIR=${BASE_DATA_DIR:-.}/${WORDPRESS_SITE_SLUG:-wordpress}/wordpress
MYSQL_DATA_DIR=${BASE_DATA_DIR:-.}/${WORDPRESS_SITE_SLUG:-wordpress}/mysql
REDIS_DATA_DIR=${BASE_DATA_DIR:-.}/${WORDPRESS_SITE_SLUG:-wordpress}/redis

MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=change-me-generate-a-long-random-password
MYSQL_ROOT_PASSWORD=change-me-generate-a-long-random-root-password
WORDPRESS_TABLE_PREFIX=wp_

# Leave REDIS_PASSWORD empty for an internal-network-only Redis, or set it
# and WordPress will use the same password.
REDIS_PASSWORD=
REDIS_DATABASE=0
WP_REDIS_PREFIX=${COMPOSE_PROJECT_NAME:-wordpress}:

# Mailgun HTTP API transport, installed as a must-use WordPress plugin.
# If MAILGUN_API_KEY is empty, WordPress falls back to its default wp_mail behavior.
MAILGUN_API_KEY=key-replace-me
MAILGUN_DOMAIN=humangame.asafut.com
MAILGUN_ENDPOINT=https://api.mailgun.net
MAILGUN_FROM_EMAIL=noreply@humangame.asafut.com
MAILGUN_FROM_NAME=ASAFUT Human Game
