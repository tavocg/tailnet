COMPOSE_PROJECT_NAME=wp-example
WORDPRESS_DOMAIN=example.com
WORDPRESS_SITE_NAME=WordPress

# Cloudflare Tunnel token from Zero Trust > Networks > Tunnels.
# Configure the tunnel public hostname:
#   example.com -> http://wordpress:80
CLOUDFLARED_TOKEN=eyJhIjoi...replace-me

BASE_DATA_DIR=/mnt/storage/data

WORDPRESS_DATA_DIR=${BASE_DATA_DIR:-./.data}/${WORDPRESS_DOMAIN}/wordpress

MYSQL_DATA_DIR=${BASE_DATA_DIR:-./.data}/${WORDPRESS_DOMAIN}/mysql
MYSQL_PASSWORD=change-me-generate-a-long-random-password
MYSQL_ROOT_PASSWORD=change-me-generate-a-long-random-root-password

REDIS_DATA_DIR=${BASE_DATA_DIR:-./.data}/${WORDPRESS_DOMAIN}/redis

# Optional; defaults to wordpress in docker-compose.yml.
# MYSQL_DATABASE=wordpress
# MYSQL_USER=wordpress
# WORDPRESS_TABLE_PREFIX=wp_

# Optional; defaults to no password, database 0, and wordpress: prefix.
# REDIS_PASSWORD=
# REDIS_DATABASE=0
# WP_REDIS_PREFIX=wordpress:

# Mailgun HTTP API transport, installed as a must-use WordPress plugin.
# If MAILGUN_API_KEY is empty, WordPress falls back to its default wp_mail behavior.
# MAILGUN_API_KEY=key-replace-me
# MAILGUN_DOMAIN=example.com
# MAILGUN_ENDPOINT=https://api.mailgun.net
# MAILGUN_FROM_EMAIL=noreply@example.com
# MAILGUN_FROM_NAME=WordPress
