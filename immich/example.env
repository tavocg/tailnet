TS_HOSTNAME=immich
TS_AUTHKEY=tskey-client-nnn
TS_EXTRA_ARGS=--advertise-tags=tag:container
TS_ALLOW_FUNNEL=false
BASE_DATA_DIR=/mnt/storage/data

# You can find documentation for all the supported env variables at
# https://immich.app/docs/install/environment-variables
UPLOAD_LOCATION=${BASE_DATA_DIR:-.}/immich/library
DB_DATA_LOCATION=${BASE_DATA_DIR:-.}/immich/db
DB_STORAGE_TYPE=HDD # Set to HDD if the DB is not stored on SSD
TZ=America/Costa_Rica
IMMICH_VERSION=release
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
