TS_HOSTNAME=sonarr
TS_AUTHKEY=tskey-client-nnn-nnn
TS_EXTRA_ARGS=--advertise-tags=tag:container
TS_ALLOW_FUNNEL=false

BASE_DATA_DIR=/mnt/storage/data

SONARR_CONFIG_DIR=${BASE_DATA_DIR:-.}/sonarr/config
SONARR_TV_DIR=/mnt/storage/media/shows
SONARR_DOWNLOADS_DIR=${BASE_DATA_DIR:-.}/qbittorrent/downloads
